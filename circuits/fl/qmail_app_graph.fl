    observe metrics: [module_init]  meters [compute_cycles]
{ make_qmail_module("qmail_rich_compose", AperturePartition::Head as u8,
    SLATier::Premium as u8, ResourceBudget8D {
        execution: 300000, hash_ops: 4000, bandwidth: 60000, storage: 80000,
        observe_events: 8000, proofs: 100, consensus: 30, memory: 67108864,
    }) }

