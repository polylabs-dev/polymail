// ═══════════════════════════════════════════════════════════════════════════════
// Graph Registration
// ═══════════════════════════════════════════════════════════════════════════════

circuit qmail_app_graph_register(
    graph: CsrStorage
) -> CsrStorage
    lex polyqlabs/qmail
    @status production
    @precision B
    @attested true
    invariant "capacity" { graph.num_nodes + POLYMAIL_MODULE_COUNT as u32 <= 4096 }
    observe metrics: [registered_module_count, registered_edge_count]
    meters [compute_cycles, memory_bytes]
{
    let (g, id_rich_compose)     = module_graph_add_module(graph, qmail_rich_compose_module())
    let (g, id_smtp_bridge)      = module_graph_add_module(g, qmail_smtp_bridge_module())
    let (g, id_route)            = module_graph_add_module(g, qmail_route_module())
    let (g, id_encrypt)          = module_graph_add_module(g, qmail_encrypt_module())
    let (g, id_classify)         = module_graph_add_module(g, qmail_classify_module())
    let (g, id_filter)           = module_graph_add_module(g, qmail_filter_module())
    let (g, id_search)           = module_graph_add_module(g, qmail_search_module())
    let (g, id_calendar)         = module_graph_add_module(g, qmail_calendar_module())
    let (g, id_rbac)             = module_graph_add_module(g, qmail_rbac_module())
    let (g, id_metering)         = module_graph_add_module(g, qmail_metering_module())
    let (g, id_platform_health)  = module_graph_add_module(g, qmail_platform_health_module())
    let (g, id_mailbox_graph)    = module_graph_add_module(g, mailbox_graph_module())
    let (g, id_thread_dag)       = module_graph_add_module(g, thread_dag_module())

    // ── Intra-graph REQUIRES edges ──────────────────────────────────────────
    // qmail_rich_compose → encrypt, route, mailbox_graph
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_rich_compose", "qmail_encrypt"), id_rich_compose, id_encrypt)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_rich_compose", "qmail_route"), id_rich_compose, id_route)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_rich_compose", "mailbox_graph"), id_rich_compose, id_mailbox_graph)

    // qmail_smtp_bridge → route, encrypt
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_smtp_bridge", "qmail_route"), id_smtp_bridge, id_route)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_smtp_bridge", "qmail_encrypt"), id_smtp_bridge, id_encrypt)

    // qmail_route → filter, classify, mailbox_graph
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_route", "qmail_filter"), id_route, id_filter)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_route", "qmail_classify"), id_route, id_classify)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_route", "mailbox_graph"), id_route, id_mailbox_graph)

    // qmail_encrypt → rbac
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_encrypt", "qmail_rbac"), id_encrypt, id_rbac)

    // qmail_classify → filter, thread_dag
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_classify", "qmail_filter"), id_classify, id_filter)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_classify", "thread_dag"), id_classify, id_thread_dag)

    // qmail_filter → mailbox_graph
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_filter", "mailbox_graph"), id_filter, id_mailbox_graph)

    // qmail_search → mailbox_graph, thread_dag
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_search", "mailbox_graph"), id_search, id_mailbox_graph)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_search", "thread_dag"), id_search, id_thread_dag)

    // qmail_calendar → filter, mailbox_graph
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_calendar", "qmail_filter"), id_calendar, id_filter)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_calendar", "mailbox_graph"), id_calendar, id_mailbox_graph)

    // qmail_metering → smtp_bridge
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_metering", "qmail_smtp_bridge"), id_metering, id_smtp_bridge)

    // qmail_platform_health → metering, smtp_bridge
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_platform_health", "qmail_metering"), id_platform_health, id_metering)
    let g = module_graph_add_edge(g, make_qmail_requires_edge("qmail_platform_health", "qmail_smtp_bridge"), id_platform_health, id_smtp_bridge)

    // thread_dag → mailbox_graph
    let g = module_graph_add_edge(g, make_qmail_requires_edge("thread_dag", "mailbox_graph"), id_thread_dag, id_mailbox_graph)

    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// Cross-Graph Bridge Edges
// ═══════════════════════════════════════════════════════════════════════════════

circuit qmail_register_bridge_edges(
    graph: CsrStorage
) -> CsrStorage
    lex polyqlabs/qmail
    @status production
    @precision B
    @attested true
    observe metrics: [bridge_count]
    meters [compute_cycles]
{
    let metering_id  = find_poly_module_id(graph, "qmail_metering")
    let rbac_id      = find_poly_module_id(graph, "qmail_rbac")
    let encrypt_id   = find_poly_module_id(graph, "qmail_encrypt")
    let calendar_id  = find_poly_module_id(graph, "qmail_calendar")

    let g = graph

    // qmail_metering → QKit metering aggregation
    if metering_id != 0xFFFFFFFF as u32 {
        let bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYMAIL_APP_LEX,
            source_module: "qmail_metering",
            target_lex: "qkit/metering",
            target_module: "qkit_metering",
            bridge_scope: BridgeScope::Platform as u8,
            shared_fields: ["send_volume", "receive_volume", "storage_bytes", "bandwidth_bytes"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, bridge, metering_id)
    }

    // qmail_rbac → QKit RBAC role composition
    if rbac_id != 0xFFFFFFFF as u32 {
        let bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYMAIL_APP_LEX,
            source_module: "qmail_rbac",
            target_lex: "qkit/rbac",
            target_module: "qkit_rbac",
            bridge_scope: BridgeScope::Platform as u8,
            shared_fields: ["role_set", "delegate_permissions", "shared_mailbox_access"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, bridge, rbac_id)
    }

    // qmail_encrypt → QKit sanitize (content sanitization)
    if encrypt_id != 0xFFFFFFFF as u32 {
        let bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYMAIL_APP_LEX,
            source_module: "qmail_encrypt",
            target_lex: "qkit/sanitize",
            target_module: "qkit_sanitize",
            bridge_scope: BridgeScope::Platform as u8,
            shared_fields: ["sanitized_body", "attachment_scan_result", "link_rewrite"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, bridge, encrypt_id)
    }

    // qmail_calendar → PolyCalendar scheduling bridge
    if calendar_id != 0xFFFFFFFF as u32 {
        let bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYMAIL_APP_LEX,
            source_module: "qmail_calendar",
            target_lex: "polyqlabs/qcalendar",
            target_module: "qcalendar_scheduling",
            bridge_scope: BridgeScope::Product as u8,
            shared_fields: ["ical_event", "meeting_invite", "rsvp_status"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, bridge, calendar_id)
    }

    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// Governance Observation Edges
// ═══════════════════════════════════════════════════════════════════════════════

circuit qmail_register_governance_edges(
    graph: CsrStorage,
    governance_lex: string
) -> CsrStorage
    lex polyqlabs/qmail
    @status production
    @precision B
    @attested true
    observe metrics: [governance_edge_count]
    meters [compute_cycles]
{
    let module_names = [
        "qmail_rich_compose", "qmail_smtp_bridge", "qmail_route",
        "qmail_encrypt", "qmail_classify", "qmail_filter",
        "qmail_search", "qmail_calendar", "qmail_rbac",
        "qmail_metering", "qmail_platform_health",
        "mailbox_graph", "thread_dag",
    ]
    let g = graph
    for name in module_names {
        let module_id = find_poly_module_id(g, name)
        if module_id != 0xFFFFFFFF as u32 {
            g = module_graph_add_governance_observe_edge(g, GovernanceObserveEdge {
                observer_lex: governance_lex,
                observer_module: "governance_core",
                observed_lex: POLYMAIL_APP_LEX,
                observed_module: name,
                observe_scope: "full",
                read_only: true,
                witness_chain_required: false,
                refresh_interval_ms: 60000,
            }, module_id)
        }
    }
    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// Metrics Store
// ═══════════════════════════════════════════════════════════════════════════════

store series qmail_app_graph_metrics
    lex polyqlabs/qmail/metrics
{
    operation: string key
    module_count: u32
    edge_count: u32
    bridge_count: u32
    governance_edge_count: u32
    register_latency_ns: u64
}

// ═══════════════════════════════════════════════════════════════════════════════
// Golden Tests
// ═══════════════════════════════════════════════════════════════════════════════

extern "rust" {
    #[module = "estream_runtime"]
    #[api = "graph"]
    #[state = "os"]
    fn graph_create() -> CsrStorage
}

test golden "register_all_13_modules" {
    exec {
        let g = graph_create()
        let g = qmail_app_graph_register(g)
    }
    assert {
        g.num_nodes == 13
        find_poly_module_id(g, "qmail_smtp_bridge") != 0xFFFFFFFF
        find_poly_module_id(g, "qmail_encrypt") != 0xFFFFFFFF
        find_poly_module_id(g, "thread_dag") != 0xFFFFFFFF
    }
}

test golden "bridge_edges_to_qkit" {
    exec {
        let g = graph_create()
        let g = qmail_app_graph_register(g)
        let before_nodes = g.num_nodes
        let g = qmail_register_bridge_edges(g)
    }
    assert {
        g.num_nodes > before_nodes
    }
}

test golden "governance_edges_all_modules" {
    exec {
        let g = graph_create()
        let g = qmail_app_graph_register(g)
        let before_edges = g.num_edges
        let g = qmail_register_governance_edges(g, "polyqlabs/governance")
    }
    assert {
        g.num_edges >= before_edges + 13
    }
}
