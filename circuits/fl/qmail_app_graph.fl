/// Spec: specs/POLYMAIL_CE_APP_GRAPH_SPEC.md
/// App Graph for PolyMail — 13 ModuleNode definitions composing the PQ-encrypted
/// email platform into Compose, Transport, Intelligence, Platform, and Graph
/// partitions. Registers intra-graph REQUIRES edges and cross-graph BRIDGE_TO
/// edges to QKit and PolyCalendar.
///
/// Epic: qmail#TBD (CE + App Graph Integration)
/// govern lex polyqlabs/qmail

lex polyqlabs/qmail

@target software
@codegen_targets ["wasm", "rust"]

import "core/deployment/module_stratum.fl" {
    ModuleNode, ModuleEdge, InterAppEdge, CsrStorage,
    CompilationReceipt, ResourceBudget8D, SemVer,
    ModuleType, AperturePartition, ModuleState, RolloutState,
    PersistencePolicy, OfflineCachePolicy, SLATier, EntitlementTier,
    EnforcementMode, BridgeScope,
    module_graph_add_module, module_graph_add_edge,
    module_graph_add_bridge_edge,
    EDGE_REQUIRES, EDGE_BRIDGE_TO,
}

import "core/deployment/cross_graph_edges.fl" {
    EDGE_GOVERNANCE_OBSERVE,
    GovernanceObserveEdge,
    module_graph_add_governance_observe_edge,
}

import "qkit/circuits/fl/qkit_app_graph.fl" {
    ProductGraphConfig, find_poly_module_id,
}

// ── Constants ──────────────────────────────────────────────────────────────────

const POLYMAIL_VERSION_MAJOR: u32 = 0
const POLYMAIL_VERSION_MINOR: u32 = 1
const POLYMAIL_VERSION_PATCH: u32 = 0
const POLYMAIL_APP_LEX: string = "polyqlabs/qmail"
const POLYMAIL_VERSION_STR: string = "0.1.0"
const POLYMAIL_MODULE_COUNT: u64 = 13

// ── Helpers ────────────────────────────────────────────────────────────────────

circuit qmail_placeholder_receipt() -> CompilationReceipt
    lex polyqlabs/qmail
    @status production
    @precision D
{
    CompilationReceipt {
        source_hash: bytes(32, 0x00),
        compiler_version: SemVer {
            major: POLYMAIL_VERSION_MAJOR,
            minor: POLYMAIL_VERSION_MINOR,
            patch: POLYMAIL_VERSION_PATCH,
            pre_release: "",
        },
        output_hash: bytes(32, 0x00),
        prime_device_id: None,
        compilation_timestamp: 0,
        reproducible_verified: false,
        receipt_signature: bytes(4627, 0x00),
    }
}

circuit make_qmail_module(
    name: string,
    partition: u8,
    sla: u8,
    budget: ResourceBudget8D
) -> ModuleNode
    lex polyqlabs/qmail
    @status production
    @precision C
    observe metrics: [module_name, aperture_partition]
    meters [compute_cycles]
{
    ModuleNode {
        name: name,
        version_major: POLYMAIL_VERSION_MAJOR,
        version_minor: POLYMAIL_VERSION_MINOR,
        version_patch: POLYMAIL_VERSION_PATCH,
        version_pre: "",
        module_type: ModuleType::SmartCircuit as u8,
        content_hash: bytes(32, 0x00),
        signature_chain: bytes(0),
        aperture_partition: partition,
        role_set: ["User", "Admin", "Delegate"],
        required_entitlement: EntitlementTier::Free as u8,
        classification_domains: [],
        max_classification_level: 0,
        compilation_receipt: qmail_placeholder_receipt(),
        source_hash: bytes(32, 0x00),
        compiler_version_major: POLYMAIL_VERSION_MAJOR,
        compiler_version_minor: POLYMAIL_VERSION_MINOR,
        prime_device_id: bytes(0),
        reproducible_verified: false,
        resource_budget: budget,
        budget_enforcement_mode: EnforcementMode::Hard as u8,
        state: ModuleState::Active as u8,
        rollout_state: RolloutState::Canary as u8,
        canary_target: None,
        persistence: PersistencePolicy::Persistent as u8,
        offline_cache_policy: OfflineCachePolicy::CacheAndVerify as u8,
        max_staleness_seconds: 3600,
        sla_tier: sla,
        preferred_locality: "",
        created_at_ms: 0,
        updated_at_ms: 0,
    }
}

circuit make_qmail_requires_edge(source: string, target: string) -> ModuleEdge
    lex polyqlabs/qmail
    @status production
    @precision D
{
    ModuleEdge {
        edge_type: EDGE_REQUIRES,
        source_module: source,
        source_version: POLYMAIL_VERSION_STR,
        target_module: target,
        target_version_constraint: ">=" ++ POLYMAIL_VERSION_STR,
        metadata: bytes(0),
    }
}

